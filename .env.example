# No secrets required for core tools.
# VIES tool uses public EU API — no key needed.

LOG_LEVEL=INFO

# ── File-system access ───────────────────────────────────────
# Tools that accept a file_path argument read from disk. Access is denied
# unless the path sits under one of the directories listed here.
# Separate multiple directories with the OS path separator (":" on Linux and
# macOS, ";" on Windows). Leave unset to disable file reads entirely and pass
# documents through the xml_content argument instead.
# FATTURAPA_ALLOWED_ROOTS=/srv/invoices:/mnt/incoming

# Escape hatch: permits every path, ignoring the roots above. Intended for
# sandboxed local experiments only — an LLM agent driving this server would be
# able to read any file the process can reach. Logs a warning when enabled.
# FATTURAPA_ALLOW_ALL_PATHS=0
